    },
    {
      "label": "Start Web Server",
      "type": "shell",
      "command": "bun",
      "args": ["run", "web"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}