{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Electron App",
      "type": "shell",
      "command": "bun",
      "args": ["run", "start"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
